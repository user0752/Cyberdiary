# ==========================================
# CyberNote Environment Variables
# ==========================================
# Copy this file to .env and customize values.
# SECRET_KEY is required — the app will refuse
# to start without a valid key of 32+ characters.

# Database (SQLite for dev, PostgreSQL connection string for production)
DATABASE_URL=sqlite+aiosqlite:///./data/cybernote.db

# Generate a unique SECRET_KEY: python -c "import secrets; print(secrets.token_urlsafe(32))"
SECRET_KEY=<generate-a-strong-key-and-paste-here>
ACCESS_TOKEN_EXPIRE_MINUTES=1440

# Auth mode: "none" (no auth) or "jwt" (JWT-based)
AUTH_MODE=none

# CORS origins (comma-separated). Use specific origins in production.
# NOTE: allow_credentials=True is enabled, so "*" is both invalid (browsers
# reject credentials with a wildcard) and insecure — the app will fall back
# to local dev origins if "*" is detected. List your trusted origins here.
ALLOWED_ORIGINS=http://localhost:5173,http://127.0.0.1:5173

# Ollama (local LLM)
OLLAMA_BASE_URL=http://localhost:11434
