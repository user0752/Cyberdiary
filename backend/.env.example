# ==========================================
# CyberNote Environment Variables
# ==========================================
# Copy this file to .env and customize values.
# SECRET_KEY is required — the app will refuse
# to start without a valid key of 32+ characters.
#
# PRODUCTION DEPLOYMENT CHECKLIST (see audit report P2-4):
#   1. SECRET_KEY  → generate via `python -c "import secrets; print(secrets.token_urlsafe(32))"`
#   2. ENCRYPTION_KEY → generate a SEPARATE key (do NOT reuse SECRET_KEY)
#   3. AUTH_MODE=jwt  (never "none" on a public network)
#   4. ALLOWED_ORIGINS → list your real frontend URL(s), NOT "*"
#   5. REDIS_URL → set with password for multi-instance; leave empty for single-process dev
#   6. ACCESS_TOKEN_EXPIRE_MINUTES → 480 (8h) is a reasonable default; lower for stricter security

# Database (SQLite for dev, PostgreSQL connection string for production)
DATABASE_URL=sqlite+aiosqlite:///./data/cybernote.db

# Generate a unique SECRET_KEY: python -c "import secrets; print(secrets.token_urlsafe(32))"
SECRET_KEY=<generate-a-strong-key-and-paste-here>
# Token lifetime (minutes). Default 480 = 8h. Lower is more secure but
# requires re-login more often. Tokens carry a jti so /auth/logout works.
ACCESS_TOKEN_EXPIRE_MINUTES=480

# Auth mode: "none" (no auth, local dev only) or "jwt" (JWT-based, required for production)
# In "jwt" mode, users must register via POST /api/v1/auth/register or login via
# POST /api/v1/auth/login to obtain a Bearer token. The frontend shows a login
# page automatically when AUTH_MODE=jwt.
AUTH_MODE=jwt

# Encryption key for API keys (AES-256-GCM). If empty, falls back to SECRET_KEY.
# Set a separate ENCRYPTION_KEY so a leaked SECRET_KEY cannot decrypt stored API keys.
# Generate: python -c "import secrets; print(secrets.token_urlsafe(32))"
ENCRYPTION_KEY=

# Redis (optional — enables multi-instance deployment)
# If empty, in-memory state is used (single-process only).
# For Docker Compose, redis is password-protected via REDIS_PASSWORD in
# docker-compose.yml; set REDIS_URL here to match, e.g.:
#   redis://:your-redis-password@redis:6379/0
# For local dev (no password), use: redis://localhost:6379/0
REDIS_URL=

# CORS origins (comma-separated). Use specific origins in production.
# NOTE: allow_credentials=True is enabled, so "*" is both invalid (browsers
# reject credentials with a wildcard) and insecure — the app will fall back
# to local dev origins if "*" is detected. List your trusted origins here.
ALLOWED_ORIGINS=http://localhost:5173,http://127.0.0.1:5173

# Ollama (local LLM)
OLLAMA_BASE_URL=http://localhost:11434
